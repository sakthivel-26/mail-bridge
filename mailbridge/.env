# MailBridge Environment Variables
# Copy this file to .env and fill in your details

# --- MCP GMAIL SERVER ---
# Gmail API Access Token for the MCP server
# This token is used by the MCP server to send emails on behalf of your Gmail account
# Get this from Google OAuth 2.0 authentication (https://developers.google.com/gmail/api/auth/web-server)
# The token must have scope: https://www.googleapis.com/auth/gmail.send
GMAIL_ACCESS_TOKEN=

# Optional (recommended): use refresh-token flow for long-term reliability.
# If you set these 3 values, server auto-refreshes access tokens.
GMAIL_REFRESH_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- GOOGLE OAUTH 2.0 ---
# For "Login with Google" - no password needed!
GOOGLE_CLIENT_ID=
